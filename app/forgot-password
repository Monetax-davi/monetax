          --w55: rgba(255,255,255,.55); --w20: rgba(255,255,255,.2);
          --w10: rgba(255,255,255,.1); --w06: rgba(255,255,255,.06);
          --bd: rgba(255,255,255,.09); --bda: rgba(26,108,255,.3);
          --ok: #00d68f; --warn: #ff4444;
          --f: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; background: var(--bg); }

        .fp-page {
          font-family: var(--f);
          background: var(--bg);
          color: var(--w);
          min-height: 100svh;
          display: flex;
          flex-direction: column;
          -webkit-font-smoothing: antialiased;
          overflow-x: hidden;
        }

        /* Grid background */
        .fp-grid {
          position: fixed; inset: 0; z-index: 0; pointer-events: none;
          background-image:
            linear-gradient(rgba(26,108,255,.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(26,108,255,.03) 1px, transparent 1px);
          background-size: 68px 68px;
          mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 10%, transparent 80%);
        }

        /* Central glow */
        .fp-glow {
          position: fixed; top: 50%; left: 50%;
          transform: translate(-50%, -50%);
          width: 700px; height: 700px; border-radius: 50%;
          background: radial-gradient(circle, rgba(26,108,255,.12) 0%, transparent 65%);
          pointer-events: none;
          animation: glowPulse 7s ease-in-out infinite;
          z-index: 1;
        }
        @keyframes glowPulse {
          0%, 100% { opacity: .7; transform: translate(-50%, -50%) scale(1); }
          50% { opacity: 1; transform: translate(-50%, -50%) scale(1.12); }
        }

        /* Rings */
        .fp-rings { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 1; }
        .fp-ring { position: absolute; border-radius: 50%; border: 1px solid rgba(26,108,255,.1); transform: translate(-50%, -50%); animation: ringPulse 5s ease-in-out infinite; }
        .fp-ring:nth-child(1) { width: 280px; height: 280px; }
        .fp-ring:nth-child(2) { width: 500px; height: 500px; animation-delay: .9s; border-color: rgba(26,108,255,.06); }
