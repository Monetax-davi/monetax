// ─── PARTICLE CANVAS ─────────────────────────────────────────────────────────
function ParticleCanvas() {
  const canvasRef = useRef<HTMLCanvasElement>(null);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let W = 0, H = 0;
    const pts: { x: number; y: number; r: number; vx: number; vy: number; a: number; blue: boolean }[] = [];
    let animId: number;

    function resize() {
      if (!canvas) return;
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }

    function init() {
      resize();
      if (window.innerWidth <= 480) return;
      for (let i = 0; i < 80; i++) {
        pts.push({
          x: Math.random() * W, y: Math.random() * H,
          r: Math.random() * 1.4 + 0.3,
          vx: (Math.random() - 0.5) * 0.28,
          vy: (Math.random() - 0.5) * 0.28,
          a: Math.random() * 0.45 + 0.1,
          blue: Math.random() < 0.65,
        });
      }

      function drawLines() {
        if (!ctx) return;
        for (let i = 0; i < pts.length; i++) {
          for (let j = i + 1; j < pts.length; j++) {
            const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
            const d = Math.sqrt(dx * dx + dy * dy);
            if (d < 130) {
              ctx.beginPath();
              ctx.moveTo(pts[i].x, pts[i].y);
              ctx.lineTo(pts[j].x, pts[j].y);
              ctx.strokeStyle = `rgba(26,108,255,${0.08 * (1 - d / 130)})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }
      }

      function anim() {
        if (!ctx) return;
        ctx.clearRect(0, 0, W, H);
        pts.forEach(p => {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
          if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = p.blue
            ? `rgba(77,148,255,${p.a})`
            : `rgba(255,255,255,${p.a * 0.45})`;
          ctx.fill();
        });
        drawLines();
        animId = requestAnimationFrame(anim);
      }
      anim();
    }

    init();
    window.addEventListener('resize', resize, { passive: true });
    return () => {
      cancelAnimationFrame(animId);
      window.removeEventListener('resize', resize);
    };
  }, []);

  return (
    <canvas
      ref={canvasRef}
      style={{ position: 'fixed', inset: 0, zIndex: 0, pointerEvents: 'none' }}
    />
  );
}

// ─── STATES ──────────────────────────────────────────────────────────────────
type State = 'idle' | 'loading' | 'success' | 'error';

// ─── PAGE ─────────────────────────────────────────────────────────────────────
export default function ForgotPasswordPage() {
  const supabase = createClientComponentClient();
  const [email, setEmail] = useState('');
  const [state, setState] = useState<State>('idle');
  const [errorMsg, setErrorMsg] = useState('');
  const [countdown, setCountdown] = useState(60);
  const [canResend, setCanResend] = useState(false);

  // Countdown após envio bem-sucedido
  useEffect(() => {
    if (state !== 'success') return;
    setCountdown(60);
    setCanResend(false);
    const interval = setInterval(() => {
      setCountdown(c => {
        if (c <= 1) {
          clearInterval(interval);
          setCanResend(true);
          return 0;
        }
        return c - 1;
      });
    }, 1000);
    return () => clearInterval(interval);
  }, [state]);

  async function handleSubmit(e?: React.FormEvent) {
    if (e) e.preventDefault();
    if (!email.trim()) {
      setErrorMsg('Digite seu email antes de continuar.');
      setState('error');
      return;
    }

    setState('loading');
    setErrorMsg('');

    const { error } = await supabase.auth.resetPasswordForEmail(email.trim(), {
      redirectTo: `${process.env.NEXT_PUBLIC_SITE_URL || 'https://monetax.com.br'}/reset-password`,
    });

    if (error) {
      setErrorMsg(
        error.message.includes('rate limit')
          ? 'Muitas tentativas. Aguarde alguns minutos e tente novamente.'
          : error.message || 'Erro ao enviar email. Tente novamente.'
      );
      setState('error');
    } else {
      setState('success');
    }
  }

  return (
    <>
      {/* ── Estilos globais (scoped) ── */}
      <style>{`
