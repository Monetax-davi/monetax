                    </div>
                    {strength.label && (
                      <div className="rp-strength-label" style={{ color: strength.color }}>{strength.label}</div>
                    )}
                    <div className="rp-req-list">
                      <div className={`rp-req${newPass.length >= 8 ? ' ok' : ''}`}>
                        <div className="rp-req-dot" />Mínimo 8 caracteres
                      </div>
                      <div className={`rp-req${/[0-9]/.test(newPass) ? ' ok' : ''}`}>
                        <div className="rp-req-dot" />Um número
                      </div>
                    </div>
                  </div>

                  {/* Confirmar senha */}
                  <div className="rp-field">
                    <label className="rp-label">Confirmar Senha</label>
                    <div className="rp-input-wrap">
                      <span className="rp-icon-l">🔐</span>
                      <input
                        type={showConfirm ? 'text' : 'password'}
                        className="rp-input"
                        placeholder="Repita a senha"
                        autoComplete="new-password"
                        value={confirmPass}
                        onChange={e => setConfirmPass(e.target.value)}
                        onKeyDown={e => e.key === 'Enter' && handleReset()}
                      />
                      <button className="rp-eye" type="button" onClick={() => setShowConfirm(v => !v)} tabIndex={-1}>
                        {showConfirm ? '🙈' : '👁'}
                      </button>
                    </div>
                    {matchLabel && (
                      <div className="rp-match" style={{ color: matchLabel.color }}>{matchLabel.text}</div>
                    )}
                  </div>

                  <button
                    className={`rp-btn${pageState === 'submitting' ? ' loading' : ''}`}
                    onClick={handleReset}
                    disabled={pageState === 'submitting'}
                  >
                    <div className="rp-shine" />
                    <span className="rp-btn-text">Salvar Nova Senha →</span>
                    <div className="rp-spinner" />
                  </button>

                  <p className="rp-footer-txt">
                    Sua senha é criptografada e armazenada com segurança.
                  </p>
                </>
              )}

            </div>
          </div>
        </div>

        <footer className="rp-page-footer">
          © 2026 Monetax · <a href="/privacidade">Privacidade</a> · <a href="/termos">Termos</a>
        </footer>
      </div>
    </>
  );
}

// ─── SUCCESS STATE COMPONENT ──────────────────────────────────────────────────
function SuccessState({ countdown, onGo }: { countdown: number; onGo: () => void }) {
  const fillRef = useRef<HTMLDivElement>(null);
  useEffect(() => {
    requestAnimationFrame(() => {
      if (fillRef.current) fillRef.current.style.width = '100%';
    });
  }, []);

  return (
    <div className="rp-end">
      <div className="rp-end-icon">🎉</div>
      <div className="rp-end-title">Senha redefinida!</div>
      <p className="rp-end-sub">
        Sua nova senha foi salva com sucesso. Você será redirecionado ao painel em instantes.
      </p>
      <div className="rp-prog">
        <div ref={fillRef} className="rp-prog-fill" />
      </div>
      <p className="rp-prog-txt">Redirecionando em {countdown}s…</p>
      <button className="rp-cta" onClick={onGo}>Ir para o Painel →</button>
    </div>
  );
}
