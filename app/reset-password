// ─── PARTICLE CANVAS ─────────────────────────────────────────────────────────
function ParticleCanvas() {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    let W = 0, H = 0;
    const pts: { x: number; y: number; r: number; vx: number; vy: number; a: number; blue: boolean }[] = [];
    let animId: number;
    function resize() { if (!canvas) return; W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
    function init() {
      resize();
      if (window.innerWidth <= 480) return;
      for (let i = 0; i < 80; i++) {
        pts.push({ x: Math.random() * W, y: Math.random() * H, r: Math.random() * 1.4 + 0.3, vx: (Math.random() - 0.5) * 0.28, vy: (Math.random() - 0.5) * 0.28, a: Math.random() * 0.45 + 0.1, blue: Math.random() < 0.65 });
      }
      function drawLines() {
        if (!ctx) return;
        for (let i = 0; i < pts.length; i++) for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y, d = Math.sqrt(dx * dx + dy * dy);
          if (d < 130) { ctx.beginPath(); ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y); ctx.strokeStyle = `rgba(26,108,255,${0.08 * (1 - d / 130)})`; ctx.lineWidth = 0.5; ctx.stroke(); }
        }
      }
      function anim() {
        if (!ctx) return;
        ctx.clearRect(0, 0, W, H);
        pts.forEach(p => { p.x += p.vx; p.y += p.vy; if (p.x < 0) p.x = W; if (p.x > W) p.x = 0; if (p.y < 0) p.y = H; if (p.y > H) p.y = 0; ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fillStyle = p.blue ? `rgba(77,148,255,${p.a})` : `rgba(255,255,255,${p.a * 0.45})`; ctx.fill(); });
        drawLines(); animId = requestAnimationFrame(anim);
      }
      anim();
    }
    init();
    window.addEventListener('resize', resize, { passive: true });
    return () => { cancelAnimationFrame(animId); window.removeEventListener('resize', resize); };
  }, []);
  return <canvas ref={canvasRef} style={{ position: 'fixed', inset: 0, zIndex: 0, pointerEvents: 'none' }} />;
}

// ─── PASSWORD STRENGTH ────────────────────────────────────────────────────────
function getStrength(v: string): { score: number; label: string; color: string } {
  let s = 0;
  if (v.length >= 8) s++;
  if (/[0-9]/.test(v)) s++;
  if (v.length >= 10) s++;
  if (v.length >= 12) s++;
  const labels = ['', 'Fraca', 'Média', 'Boa', 'Forte'];
  const colors = ['', '#ff4444', '#f59e0b', '#00d68f', '#00d68f'];
  return { score: s, label: v.length ? labels[s] : '', color: colors[s] || '#fff' };
}

