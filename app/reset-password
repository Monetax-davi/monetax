type PageState = 'loading-token' | 'form' | 'success' | 'invalid' | 'submitting';

export default function ResetPasswordPage() {
  const supabase = createClientComponentClient();
  const router = useRouter();

  const [pageState, setPageState] = useState<PageState>('loading-token');
  const [newPass, setNewPass] = useState('');
  const [confirmPass, setConfirmPass] = useState('');
  const [showNew, setShowNew] = useState(false);
  const [showConfirm, setShowConfirm] = useState(false);
  const [errorMsg, setErrorMsg] = useState('');
  const [countdown, setCountdown] = useState(3);

  // ─── Extrai token do hash e autentica sessão ───────────────────────────────
  useEffect(() => {
    const hash = window.location.hash.substring(1);
    const params = new URLSearchParams(hash);
    const accessToken = params.get('access_token');
    const type = params.get('type');
    const refreshToken = params.get('refresh_token') ?? '';

    // Limpa hash da URL por segurança
    if (window.history?.replaceState) {
      window.history.replaceState(null, '', window.location.pathname);
    }

    if (!accessToken || type !== 'recovery') {
      // Verifica se já existe sessão ativa (usuário veio pelo pkce flow)
      supabase.auth.getSession().then(({ data }) => {
        if (data.session) {
          setPageState('form');
        } else {
          setPageState('invalid');
        }
      });
      return;
    }

    // Seta a sessão com o token recebido no email
    supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken })
      .then(({ error }) => {
        if (error) {
          setPageState('invalid');
        } else {
          setPageState('form');
        }
      });
  }, [supabase.auth]);

  // ─── Countdown redirect ao sucesso ───────────────────────────────────────
  useEffect(() => {
    if (pageState !== 'success') return;
    setCountdown(3);
    const interval = setInterval(() => {
      setCountdown(c => {
        if (c <= 1) { clearInterval(interval); router.push('/dashboard'); return 0; }
        return c - 1;
      });
    }, 1000);
    return () => clearInterval(interval);
  }, [pageState, router]);

  // ─── Submit ────────────────────────────────────────────────────────────────
  async function handleReset() {
    setErrorMsg('');

    if (!newPass || !confirmPass) { setErrorMsg('Preencha os dois campos.'); return; }
    if (newPass.length < 8) { setErrorMsg('A senha deve ter no mínimo 8 caracteres.'); return; }
    if (!/[0-9]/.test(newPass)) { setErrorMsg('A senha deve conter pelo menos um número.'); return; }
    if (newPass !== confirmPass) { setErrorMsg('As senhas não coincidem.'); return; }

    setPageState('submitting');

    const { error } = await supabase.auth.updateUser({ password: newPass });

    if (error) {
      const msg = error.message.toLowerCase();
      if (msg.includes('expired') || msg.includes('invalid') || msg.includes('session')) {
        setPageState('invalid');
      } else {
        setErrorMsg(error.message || 'Erro ao redefinir senha. Tente novamente.');
        setPageState('form');
      }
    } else {
      setPageState('success');
    }
  }

  const strength = getStrength(newPass);
  const matchLabel = confirmPass
    ? newPass === confirmPass
      ? { text: '✓ Senhas coincidem', color: '#00d68f' }
      : { text: '✗ Senhas não coincidem', color: '#ff4444' }
    : null;

